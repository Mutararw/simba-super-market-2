/* --- Footer Styling --- */
.site-footer {
  background: var(--secondary-dark);
  color: white;
  padding: 5rem 0 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1.2fr;
  gap: 4rem;
  margin-bottom: 4rem;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  margin-bottom: 1.5rem;
}

.footer-brand-badge {
  background: var(--primary);
  color: white;
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 1.4rem;
}

.footer-brand-text {
  font-weight: 800;
  font-size: 1.5rem;
  letter-spacing: -0.02em;
}

.footer-about {
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  margin-bottom: 2rem;
  max-width: 380px;
}

.footer-social {
  display: flex;
  gap: 1rem;
}

.footer-icon-btn {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.footer-icon-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
  transform: translateY(-3px);
}

.footer-title {
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 1.5rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.footer-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.footer-list a {
  color: rgba(255, 255, 255, 0.6);
  transition: color 0.2s ease;
}

.footer-list a:hover {
  color: var(--primary);
}

.footer-contact-item {
  display: flex;
  align-items: flex-start;
  gap: 0.8rem;
  color: rgba(255, 255, 255, 0.6);
}

.footer-contact-item a {
  color: rgba(255, 255, 255, 0.6);
}

.footer-copy {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.4);
  font-size: 0.9rem;
}
